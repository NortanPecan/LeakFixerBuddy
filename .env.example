# LeakFixer Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# SQLite (Local Development)
# ============================================
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ============================================
# Supabase PostgreSQL (Production)
# ============================================
# Get connection strings from Supabase Dashboard → Connect button
# Note: Password must be URL-encoded if it contains special chars (! = %21)

# Pooler connection (for serverless/edge, port 6543)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (for migrations, port 5432)
# DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# Example with URL-encoded password (Ss552586!!FiveChance2001!):
# DATABASE_URL="postgresql://postgres:Ss552586%21%21FiveChance2001%21@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://postgres:Ss552586%21%21FiveChance2001%21@db.zhpwehjbonzffpxdrbyl.supabase.co:5432/postgres"
