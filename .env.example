# LeakFixer Buddy - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# BRANCH SETUP
# ============================================
# master (sandbox): SQLite, no external services required
# main (production): Supabase PostgreSQL, Telegram Mini App

# ============================================
# OPTION 1: SANDBOX MODE (branch: master)
# ============================================
# Local SQLite database - no external services needed
DATABASE_URL="file:./db/custom.db"

# Demo mode - bypasses Telegram auth for local testing
# Set to "true" to use demo user without Telegram
DEMO_MODE="true"

# ============================================
# OPTION 2: PRODUCTION MODE (branch: main)
# ============================================
# Supabase PostgreSQL connection strings
# Get from Supabase Dashboard → Project Settings → Database

# Connection pooling (for Vercel/serverless, port 6543)
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (for migrations, port 5432)
# DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Telegram Bot Token (for validating initData)
# Get from @BotFather in Telegram
# TELEGRAM_BOT_TOKEN="your-bot-token-here"

# ============================================
# URL ENCODING NOTE
# ============================================
# If your password contains special characters, URL-encode them:
# ! = %21  @ = %40  # = %23  $ = %24  % = %25
# & = %26  * = %2A  + = %2B  = = %3D  ? = %3F

# Example password: "MyPass!!" → "MyPass%21%21"

# ============================================
# VERCEL DEPLOYMENT
# ============================================
# Set these in Vercel Dashboard → Settings → Environment Variables:
# - DATABASE_URL (pooling connection)
# - DIRECT_DATABASE_URL (direct connection)
# - TELEGRAM_BOT_TOKEN (optional, for production)
