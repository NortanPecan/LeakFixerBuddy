// LeakFixer Mini App - Prisma Schema for Supabase (Production)
// PostgreSQL - Telegram Mini App with future email/phone auth support
// 
// DEPLOYMENT NOTES:
// 1. Set DATABASE_URL to Supabase connection pooling URL (port 6543)
// 2. Set DIRECT_DATABASE_URL to Supabase direct URL (port 5432)
// 3. Run migrations with: prisma migrate deploy
//
// BRANCH: main (production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================
// CORE DOMAIN - User & Authentication
// ============================================

/// App user - Telegram Mini App primary identity
/// Supports future email/phone authentication
model AppUser {
  id        String  @id @default(uuid()) @db.Uuid
  
  // Telegram identity (primary auth method)
  telegramId           BigInt?  @unique @map("telegram_id") @db.BigInt
  telegramUsername     String?  @map("telegram_username")
  telegramFirstName    String?  @map("telegram_first_name")
  telegramLastName     String?  @map("telegram_last_name")
  telegramLanguageCode String?  @default("ru") @map("telegram_language_code")
  telegramPhotoUrl     String?  @map("telegram_photo_url")
  
  // Legacy fields (for backwards compatibility with old miniapp)
  username  String?
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  photoUrl  String?  @map("photo_url")
  language  String   @default("ru")
  
  // Future auth methods (phone/email) - currently unused
  // Will integrate with Supabase Auth in the future
  email          String?   @unique
  phone          String?   @unique
  emailVerified  DateTime? @map("email_verified")
  phoneVerified  DateTime? @map("phone_verified")
  
  // User progress & gamification
  day    Int @default(1)
  streak Int @default(0)
  points Int @default(0)
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  
  // Auth metadata
  authProvider String?   @default("telegram") @map("auth_provider") // telegram, email, phone
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz

  // Relations
  profile            UserProfile?
  fitnessDaily       FitnessDaily[]
  dailyStates        DailyState[]
  measurements       Measurement[]
  habits             Habit[]
  habitLogs          HabitLog[]
  gymPeriods         GymPeriod[]
  buddies            Buddy[]
  rituals            Ritual[]
  ritualCompletions  RitualCompletion[]
  userAttributes     UserAttribute[]
  achievements       Achievement[]
  chains             Chain[]
  tasks              Task[]
  notes              Note[]
  contentItems       ContentItem[]
  settings           UserSettings?
  feedbacks          Feedback[]
  accounts           Account[]
  categories         Category[]
  transactions       Transaction[]
  challenges         Challenge[]
  supplements        Supplement[]
  supplementIntakes  SupplementIntake[]
  foodEntries        FoodEntry[]

  @@index([telegramId])
  @@index([email])
  @@index([phone])
  @@map("app_users")
}

/// User fitness profile - extended user data
model UserProfile {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  weight        Float?
  height        Float?
  age           Int?
  sex           String?  // "male" or "female" - for BMR calculation
  targetWeight  Float?   @map("target_weight")
  targetCalories Int?    @map("target_calories")
  workProfile   String?  @map("work_profile") // sedentary, mixed, physical, variable
  waterBaseline Int      @default(2000) @map("water_baseline")
  
  // Body measurements
  waist         Float?
  hips          Float?
  chest         Float?
  bicep         Float?
  thigh         Float?
  
  // Personal info
  bio           String?
  
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// Lessons for 30-day loop
model Lesson {
  id          String   @id @default(uuid()) @db.Uuid
  day         Int      @unique
  title       String
  description String?
  videoUrl    String?  @map("video_url")
  content     String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("lessons")
}

// ============================================
// HABITS DOMAIN
// ============================================

/// Habit definitions (user-created)
model Habit {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  icon      String?
  color     String?
  frequency String?
  target    Int?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user AppUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@map("habits")
}

/// Habit completion logs
model HabitLog {
  id        String   @id @default(uuid()) @db.Uuid
  habitId   String   @map("habit_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @default(now()) @db.Timestamptz
  completed Boolean  @default(false)
  count     Int      @default(1)
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  habit Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@map("habit_logs")
}

// ============================================
// FITNESS DOMAIN
// ============================================

/// Daily fitness data snapshot
model FitnessDaily {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  date        DateTime @default(now()) @db.Timestamptz
  activities  String?  // JSON
  foods       String?  // JSON
  water       Int      @default(0)
  waterTarget Int      @default(2000) @map("water_target")
  supplements String?  // JSON
  mood        Int?
  energy      Int?
  gymState    String?  @map("gym_state")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("fitness_daily")
}

/// Daily state (mood, energy)
model DailyState {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @default(now()) @db.Timestamptz
  mood      Int?
  energy    Int?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_state")
}

/// Measurements log
model Measurement {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   // waist, hips, chest, bicep, thigh, weight
  value     Float
  unit      String?
  date      DateTime @default(now()) @db.Timestamptz
  note      String?
  photoUrl  String?  @map("photo_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("measurements")
}

// ============================================
// GYM DOMAIN
// ============================================

/// Training period (macrocycle)
model GymPeriod {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  name            String
  type            String    // split, fullbody, ppl, upper_lower, custom
  cycleLength     Int       @default(7) @map("cycle_length")
  workoutsPerCycle Int      @default(4) @map("workouts_per_cycle")
  totalCycles     Int       @default(8) @map("total_cycles")
  currentCycle    Int       @default(1) @map("current_cycle")
  currentDay      Int       @default(1) @map("current_day")
  startDate       DateTime  @default(now()) @map("start_date") @db.Timestamptz
  endDate         DateTime? @map("end_date") @db.Timestamptz
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user     AppUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycles   GymCycle[]
  workouts GymWorkout[]

  @@map("gym_periods")
}

/// Training cycle (mesocycle within period)
model GymCycle {
  id        String    @id @default(uuid()) @db.Uuid
  periodId  String    @map("period_id") @db.Uuid
  cycleNum  Int       @map("cycle_num")
  startDate DateTime  @default(now()) @map("start_date") @db.Timestamptz
  endDate   DateTime? @map("end_date") @db.Timestamptz
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  period   GymPeriod    @relation(fields: [periodId], references: [id], onDelete: Cascade)
  workouts GymWorkout[]

  @@map("gym_cycles")
}

/// Individual workout
model GymWorkout {
  id           String    @id @default(uuid()) @db.Uuid
  periodId     String    @map("period_id") @db.Uuid
  cycleId      String?   @map("cycle_id") @db.Uuid
  date         DateTime  @default(now()) @db.Timestamptz
  dayOfWeek    Int       @map("day_of_week") // 1-7
  workoutNum   Int       @map("workout_num")
  name         String?
  muscleGroups String?   @map("muscle_groups") // JSON array
  duration     Int?
  completed    Boolean   @default(false)
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  period    GymPeriod     @relation(fields: [periodId], references: [id], onDelete: Cascade)
  cycle     GymCycle?     @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  exercises GymExercise[]

  @@map("gym_workouts")
}

/// Exercise in a workout
model GymExercise {
  id          String   @id @default(uuid()) @db.Uuid
  workoutId   String   @map("workout_id") @db.Uuid
  name        String
  muscleGroup String?  @map("muscle_group")
  order       Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  workout GymWorkout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sets    GymExerciseSet[]

  @@map("gym_exercises")
}

/// Set in an exercise
model GymExerciseSet {
  id         String   @id @default(uuid()) @db.Uuid
  exerciseId String   @map("exercise_id") @db.Uuid
  setNum     Int      @map("set_num")
  weight     Float?
  reps       Int?
  duration   Int?
  completed  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  exercise GymExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("gym_exercise_sets")
}

// ============================================
// BUDDIES (accountability partners)
// ============================================

model Buddy {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  partnerId    String   @map("partner_id")
  partnerName  String   @map("partner_name")
  partnerPhoto String?  @map("partner_photo")
  status       String   @default("pending") // pending, accepted, rejected
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, partnerId])
  @@map("buddies")
}

// ============================================
// RITUALS MODULE
// ============================================

/// Ritual definition
model Ritual {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  title        String
  type         String    @default("regular") // regular, bad, one_time
  category     String    // health, money, learning, relationships, mind, productivity
  days         String    @default("[]") // JSON array
  timeWindow   String    @default("any") @map("time_window") // morning, day, evening, any
  reminder     Boolean   @default(false)
  reminderTime String?   @map("reminder_time")
  goalShort    String?   @map("goal_short")
  description  String?
  isFromPreset Boolean   @default(false) @map("is_from_preset")
  presetId     String?   @map("preset_id")
  status       String    @default("active") // active, archived
  attributes   String    @default("[]") // JSON array
  sortOrder    Int       @default(0) @map("sort_order")
  contentId    String?   @map("content_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user        AppUser            @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions RitualCompletion[]
  content     ContentItem?       @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@map("rituals")
}

/// Ritual completion log
model RitualCompletion {
  id        String   @id @default(uuid()) @db.Uuid
  ritualId  String   @map("ritual_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @default(now()) @db.Timestamptz
  completed Boolean  @default(true)
  note      String?
  mood      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  ritual Ritual  @relation(fields: [ritualId], references: [id], onDelete: Cascade)
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ritualId, date])
  @@map("ritual_completions")
}

/// User attributes (health, mind, will)
model UserAttribute {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  key       String   // health, mind, will
  points    Int      @default(0)
  level     Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("user_attributes")
}

/// User achievements
model Achievement {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  code       String   // RITUAL_STREAK_3, etc.
  metadata   String?  // JSON
  obtainedAt DateTime @default(now()) @map("obtained_at") @db.Timestamptz

  // Relations
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@map("achievements")
}

// ============================================
// NOTES MODULE
// ============================================

/// Note (thought, diary, content)
model Note {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  text      String
  type      String   @default("thought") // thought, diary, content
  zone      String   @default("general")
  date      DateTime @default(now()) @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user  AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  links NoteLink[]

  @@map("notes")
}

/// Link between note and other entities
model NoteLink {
  id        String   @id @default(uuid()) @db.Uuid
  noteId    String   @map("note_id") @db.Uuid
  entity    String   // task, ritual, chain, content
  entityId  String   @map("entity_id")
  fragment  String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, entity, entityId])
  @@map("note_links")
}

// ============================================
// TASKS/CHAINS MODULE
// ============================================

/// Task chain (sequence of steps toward a goal)
model Chain {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String
  status    String   @default("active") // active, completed
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user  AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@map("chains")
}

/// Task (step in a chain or standalone)
model Task {
  id         String    @id @default(uuid()) @db.Uuid
  chainId    String?   @map("chain_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  text       String
  status     String    @default("todo") // todo, done
  order      Int       @default(0)
  date       DateTime? @db.Timestamptz
  time       String?
  zone       String?
  ritualId   String?   @map("ritual_id") @db.Uuid
  noteId     String?   @map("note_id") @db.Uuid
  contentId  String?   @map("content_id") @db.Uuid
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user    AppUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chain   Chain?       @relation(fields: [chainId], references: [id], onDelete: SetNull)
  content ContentItem? @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

// ============================================
// CONTENT MODULE (Development/Learning)
// ============================================

/// Content item (book, movie, course, podcast, video)
model ContentItem {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  type          String    // book, movie, course, podcast, video
  title         String
  status        String    @default("planned") // planned, in_progress, completed
  source        String?
  url           String?
  zone          String    @default("general")
  totalUnits    Int?      @map("total_units")
  currentUnits  Int?      @map("current_units")
  unitType      String?   @map("unit_type")
  author        String?
  imageUrl      String?   @map("image_url")
  description   String?
  notes         String?
  startedAt     DateTime? @map("started_at") @db.Timestamptz
  completedAt   DateTime? @map("completed_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user    AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  links   ContentLink[]
  tasks   Task[]
  rituals Ritual[]

  @@map("content_items")
}

/// Link between content and other entities
model ContentLink {
  id        String   @id @default(uuid()) @db.Uuid
  contentId String   @map("content_id") @db.Uuid
  entity    String
  entityId  String   @map("entity_id")
  fragment  String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  content ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, entity, entityId])
  @@map("content_links")
}

// ============================================
// SETTINGS MODULE
// ============================================

/// User settings (notifications, zones, theme)
model UserSettings {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  ritualReminders      Boolean  @default(true) @map("ritual_reminders")
  taskReminders        Boolean  @default(true) @map("task_reminders")
  zoneSteamEnabled     Boolean  @default(true) @map("zone_steam_enabled")
  zoneLeakfixerEnabled Boolean  @default(true) @map("zone_leakfixer_enabled")
  zoneAiEnabled        Boolean  @default(true) @map("zone_ai_enabled")
  zonePokerEnabled     Boolean  @default(true) @map("zone_poker_enabled")
  zoneHealthEnabled    Boolean  @default(true) @map("zone_health_enabled")
  theme                String   @default("system")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ============================================
// FEEDBACK MODULE
// ============================================

/// User feedback (bugs, ideas, questions, reviews)
model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   // bug, idea, question, review
  message   String
  status    String   @default("new") // new, read, resolved
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}

// ============================================
// FINANCE MODULE
// ============================================

/// Financial account (cash, card, poker bankroll, etc.)
model Account {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String
  type           String   @default("cash") // cash, card, poker, steam, other
  initialBalance Float    @default(0) @map("initial_balance")
  icon           String?
  color          String?
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user         AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("accounts")
}

/// Finance category (envelope/budget category)
model Category {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  name          String
  zone          String   @default("general")
  monthlyTarget Float?   @map("monthly_target")
  icon          String?
  color         String?
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user         AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("categories")
}

/// Financial transaction
model Transaction {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  accountId   String   @map("account_id") @db.Uuid
  categoryId  String?  @map("category_id") @db.Uuid
  date        DateTime @default(now()) @db.Timestamptz
  amount      Float
  description String?
  zone        String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user     AppUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

// ============================================
// CHALLENGES MODULE
// ============================================

/// Personal challenge (ritual streak, chain completion, custom goal)
model Challenge {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  name       String
  type       String    // ritual, chain, custom
  zone       String    @default("general")
  chainId    String?   @map("chain_id") @db.Uuid
  config     String    @default("{}") // JSON
  duration   Int       @default(30)
  progress   Int       @default(0)
  startDate  DateTime  @default(now()) @map("start_date") @db.Timestamptz
  endDate    DateTime? @map("end_date") @db.Timestamptz
  status     String    @default("active") // active, completed, failed
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user            AppUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  progressDetails ChallengeProgress[]

  @@map("challenges")
}

/// Challenge progress tracking
model ChallengeProgress {
  id            String   @id @default(uuid()) @db.Uuid
  challengeId   String   @map("challenge_id") @db.Uuid
  daysCompleted Int      @default(0) @map("days_completed")
  currentStreak Int      @default(0) @map("current_streak")
  lastCheckedAt DateTime @default(now()) @map("last_checked_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@map("challenge_progress")
}

// ============================================
// HEALTH MODULE (Supplements, Food, Water)
// ============================================

/// Supplement definition (vitamin, mineral, etc.)
model Supplement {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  name         String
  dosage       String?
  unit         String   @default("мг")
  standardDose Float    @default(1) @map("standard_dose")
  timeWindow   String   @default("any") @map("time_window")
  days         String   @default("[1,2,3,4,5,6,7]")
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user    AppUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  intakes SupplementIntake[]

  @@map("supplements")
}

/// Supplement intake log
model SupplementIntake {
  id           String   @id @default(uuid()) @db.Uuid
  supplementId String   @map("supplement_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  date         DateTime @default(now()) @db.Timestamptz
  time         String?
  dose         Float    @default(1)
  checked      Boolean  @default(false)
  note         String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  supplement Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)
  user       AppUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([supplementId, date])
  @@map("supplement_intakes")
}

/// Food entry (meal tracking)
model FoodEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @default(now()) @db.Timestamptz
  mealType  String   @default("snack") @map("meal_type")
  name      String
  calories  Int?
  protein   Float?
  fat       Float?
  carbs     Float?
  amount    String?
  quality   String?
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("food_entries")
}
